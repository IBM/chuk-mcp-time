{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended",
    ":automergeMinor",
    ":automergeDigest"
  ],
  "platformAutomerge": true,
  "packageRules": [
    {
      "description": "Automerge CI-validated GitHub Actions updates (incl. major)",
      "matchManagers": ["github-actions"],
      "automerge": true
    },
    {
      "description": "Pause Rust crate updates until rapier-service compiles and is covered by CI",
      "matchManagers": ["cargo"],
      "enabled": false
    }
  ]
}
